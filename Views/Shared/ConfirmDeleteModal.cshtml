<style>
    :root {
        --primary: #ef4444;
        --accent: #f97316;
        --success: #10b981;
        --dark: #0f172a;
        --light: #f8fafc;
    }

    /* Backdrop avec animation fluide */
    .delete-modal-backdrop {
        position: fixed;
        top: 0;
        left: 0;
        right: 0;
        bottom: 0;
        background: rgba(15, 23, 42, 0.6);
        backdrop-filter: blur(8px);
        display: none;
        align-items: center;
        justify-content: center;
        z-index: 9999;
        animation: backdropFadeIn 0.4s ease-out;
    }

    .delete-modal-backdrop.active {
        display: flex;
    }

    /* Modal container avec effets WOW */
    .delete-modal {
        background: linear-gradient(135deg, rgba(255, 255, 255, 0.95) 0%, rgba(248, 250, 252, 0.95) 100%);
        border-radius: 20px;
        box-shadow: 0 25px 50px rgba(0, 0, 0, 0.2), 
                    0 0 100px rgba(239, 68, 68, 0.1);
        border: 1px solid rgba(255, 255, 255, 0.8);
        max-width: 450px;
        width: 90%;
        overflow: hidden;
        animation: modalScaleIn 0.5s cubic-bezier(0.34, 1.56, 0.64, 1);
        backdrop-filter: blur(20px);
    }

    /* Warning header avec gradient animé */
    .delete-modal-header {
        background: linear-gradient(135deg, #ef4444 0%, #f97316 100%);
        padding: 40px 30px;
        text-align: center;
        position: relative;
        overflow: hidden;
    }

    .delete-modal-header::before {
        content: '';
        position: absolute;
        top: -50%;
        left: -50%;
        width: 200%;
        height: 200%;
        background: radial-gradient(circle, rgba(255, 255, 255, 0.1) 0%, transparent 70%);
        animation: shimmer 3s ease-in-out infinite;
    }

    .delete-modal-warning-icon {
        font-size: 3.5rem;
        color: white;
        margin-bottom: 15px;
        display: inline-block;
        animation: iconBounce 0.6s cubic-bezier(0.34, 1.56, 0.64, 1);
        position: relative;
        z-index: 1;
    }

    .delete-modal-header h2 {
        color: white;
        font-size: 1.5rem;
        font-weight: 700;
        margin: 0;
        letter-spacing: -0.5px;
        position: relative;
        z-index: 1;
    }

    /* Body content */
    .delete-modal-body {
        padding: 40px 30px;
        animation: fadeInUp 0.6s ease-out 0.2s both;
    }

    .delete-event-name {
        background: linear-gradient(135deg, rgba(239, 68, 68, 0.1), rgba(249, 115, 22, 0.1));
        border-radius: 12px;
        padding: 16px;
        margin: 20px 0;
        border-left: 4px solid #ef4444;
        font-weight: 600;
        color: #1f2937;
        font-size: 1.05rem;
        animation: slideInLeft 0.6s ease-out 0.3s both;
    }

    .delete-modal-message {
        color: #4b5563;
        line-height: 1.6;
        margin: 20px 0;
        font-size: 0.95rem;
        animation: fadeIn 0.6s ease-out 0.4s both;
    }

    .delete-warning-list {
        list-style: none;
        padding: 20px;
        background: rgba(239, 68, 68, 0.05);
        border-radius: 12px;
        margin: 20px 0;
    }

    .delete-warning-list li {
        color: #6b7280;
        margin: 10px 0;
        display: flex;
        align-items: center;
        gap: 10px;
        font-size: 0.9rem;
        animation: slideInLeft 0.5s ease-out backwards;
    }

    .delete-warning-list li:nth-child(1) { animation-delay: 0.5s; }
    .delete-warning-list li:nth-child(2) { animation-delay: 0.6s; }
    .delete-warning-list li:nth-child(3) { animation-delay: 0.7s; }

    .delete-warning-list li::before {
        content: '✕';
        font-weight: bold;
        color: #ef4444;
        font-size: 1.2rem;
        display: inline-flex;
        align-items: center;
        justify-content: center;
    }

    /* Actions footer */
    .delete-modal-footer {
        padding: 30px;
        display: flex;
        gap: 12px;
        background: linear-gradient(135deg, rgba(248, 250, 252, 0.5) 0%, rgba(241, 245, 249, 0.5) 100%);
        border-top: 1px solid rgba(0, 0, 0, 0.05);
        animation: fadeInUp 0.6s ease-out 0.4s both;
    }

    /* Button styles */
    .delete-btn-cancel {
        flex: 1;
        padding: 14px 20px;
        border: 2px solid #e5e7eb;
        background: white;
        color: #4b5563;
        border-radius: 10px;
        font-weight: 600;
        cursor: pointer;
        transition: all 0.3s cubic-bezier(0.34, 1.56, 0.64, 1);
        font-size: 0.95rem;
        letter-spacing: 0.3px;
    }

    .delete-btn-cancel:hover {
        background: #f3f4f6;
        border-color: #d1d5db;
        transform: translateY(-2px);
        box-shadow: 0 8px 20px rgba(0, 0, 0, 0.08);
    }

    .delete-btn-confirm {
        flex: 1;
        padding: 14px 20px;
        background: linear-gradient(135deg, #ef4444 0%, #f97316 100%);
        color: white;
        border: none;
        border-radius: 10px;
        font-weight: 600;
        cursor: pointer;
        transition: all 0.3s cubic-bezier(0.34, 1.56, 0.64, 1);
        font-size: 0.95rem;
        letter-spacing: 0.3px;
        position: relative;
        overflow: hidden;
    }

    .delete-btn-confirm::before {
        content: '';
        position: absolute;
        top: 50%;
        left: 50%;
        width: 0;
        height: 0;
        border-radius: 50%;
        background: rgba(255, 255, 255, 0.3);
        transform: translate(-50%, -50%);
        transition: width 0.5s ease, height 0.5s ease;
    }

    .delete-btn-confirm:hover::before {
        width: 300px;
        height: 300px;
    }

    .delete-btn-confirm:hover {
        transform: translateY(-2px);
        box-shadow: 0 15px 35px rgba(239, 68, 68, 0.4);
    }

    .delete-btn-confirm:active {
        transform: translateY(0);
    }

    /* Animations */
    @@keyframes backdropFadeIn {
        from {
            opacity: 0;
        }
        to {
            opacity: 1;
        }
    }

    @@keyframes modalScaleIn {
        from {
            opacity: 0;
            transform: scale(0.9) translateY(20px);
        }
        to {
            opacity: 1;
            transform: scale(1) translateY(0);
        }
    }

    @@keyframes iconBounce {
        0%, 100% {
            transform: translateY(0) scale(1);
        }
        50% {
            transform: translateY(-10px) scale(1.05);
        }
    }

    @@keyframes fadeInUp {
        from {
            opacity: 0;
            transform: translateY(20px);
        }
        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    @@keyframes fadeIn {
        from {
            opacity: 0;
        }
        to {
            opacity: 1;
        }
    }

    @@keyframes slideInLeft {
        from {
            opacity: 0;
            transform: translateX(-20px);
        }
        to {
            opacity: 1;
            transform: translateX(0);
        }
    }

    @@keyframes shimmer {
        0%, 100% {
            transform: translate(0, 0);
        }
        50% {
            transform: translate(50px, 50px);
        }
    }

    @@media (max-width: 600px) {
        .delete-modal {
            max-width: 90vw;
        }

        .delete-modal-header {
            padding: 30px 20px;
        }

        .delete-modal-warning-icon {
            font-size: 2.5rem;
        }

        .delete-modal-header h2 {
            font-size: 1.2rem;
        }

        .delete-modal-body {
            padding: 25px 20px;
        }

        .delete-modal-footer {
            padding: 20px;
            flex-direction: column;
        }
    }
</style>

<div class="delete-modal-backdrop" id="deleteModalBackdrop">
    <div class="delete-modal">
        <div class="delete-modal-header">
            <div class="delete-modal-warning-icon">
                <i class="fas fa-exclamation-triangle"></i>
            </div>
            <h2>Supprimer cet événement ?</h2>
        </div>

        <div class="delete-modal-body">
            <p class="delete-modal-message">
                Vous êtes sur le point de supprimer l'événement suivant :
            </p>
            <div class="delete-event-name" id="deleteEventName">
                <!-- Event name will be inserted here -->
            </div>

            <p class="delete-modal-message">
                Cette action est <strong>permanente et irréversible</strong>. Assurez-vous que c'est vraiment ce que vous souhaitez.
            </p>

            <ul class="delete-warning-list">
                <li>Toutes les inscriptions seront perdues</li>
                <li>Les données ne pourront pas être récupérées</li>
                <li>Les notifications seront envoyées aux participants</li>
            </ul>
        </div>

        <div class="delete-modal-footer">
            <button type="button" class="delete-btn-cancel" onclick="cancelDelete()">
                <i class="fas fa-times me-2"></i>Annuler
            </button>
            <button type="button" class="delete-btn-confirm" onclick="confirmDeleteAction()">
                <i class="fas fa-trash-alt me-2"></i>Supprimer
            </button>
        </div>
    </div>
</div>

<script>
    let deleteFormId = null;

    function showDeleteConfirm(eventId, eventTitle) {
        deleteFormId = 'deleteForm-' + eventId;
        document.getElementById('deleteEventName').textContent = eventTitle;
        document.getElementById('deleteModalBackdrop').classList.add('active');
        document.body.style.overflow = 'hidden';
    }

    function cancelDelete() {
        document.getElementById('deleteModalBackdrop').classList.remove('active');
        document.body.style.overflow = 'auto';
        deleteFormId = null;
    }

    function confirmDeleteAction() {
        if (deleteFormId && document.getElementById(deleteFormId)) {
            document.getElementById(deleteFormId).submit();
        }
    }

    // Close modal on Escape key
    document.addEventListener('keydown', function(event) {
        if (event.key === 'Escape') {
            cancelDelete();
        }
    });

    // Close modal on backdrop click
    document.getElementById('deleteModalBackdrop').addEventListener('click', function(event) {
        if (event.target === this) {
            cancelDelete();
        }
    });
</script>
