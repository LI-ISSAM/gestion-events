@model GestionEvenements.Models.RegisterViewModel
@{
    ViewData["Title"] = "Inscription";
}

<style>
    :root {
        --primary: #059669;
        --primary-dark: #047857;
        --accent: #d97706;
        --accent-light: #fbbf24;
        --danger: #ef4444;
        --text-dark: #1e293b;
        --text-muted: #64748b;
        --glass-bg: rgba(255, 255, 255, 0.95);
        --glass-border: rgba(5, 150, 105, 0.2);
    }

    @@keyframes fadeInUp {
        from { opacity: 0; transform: translateY(50px); }
        to { opacity: 1; transform: translateY(0); }
    }

    @@keyframes float {
        0%, 100% { transform: translateY(0) rotate(0deg); }
        50% { transform: translateY(-30px) rotate(5deg); }
    }

    @@keyframes shimmer {
        0% { background-position: -200% center; }
        100% { background-position: 200% center; }
    }

    @@keyframes pulse-ring {
        0% { transform: scale(0.8); opacity: 1; }
        100% { transform: scale(2.5); opacity: 0; }
    }

    @@keyframes icon-bounce {
        0%, 100% { transform: translateY(0); }
        50% { transform: translateY(-10px); }
    }

    @@keyframes checkmark {
        0% { stroke-dashoffset: 100; }
        100% { stroke-dashoffset: 0; }
    }

    .register-page {
        min-height: 100vh;
        display: flex;
        align-items: center;
        justify-content: center;
        background: linear-gradient(135deg, #ecfdf5 0%, #f0fdf4 30%, #fef3c7 70%, #fefce8 100%);
        padding: 40px 20px;
        position: relative;
        overflow: hidden;
    }

    .register-page::before {
        content: '';
        position: absolute;
        top: -20%;
        right: -10%;
        width: 600px;
        height: 600px;
        background: radial-gradient(circle, rgba(217, 119, 6, 0.12) 0%, transparent 70%);
        animation: float 20s ease-in-out infinite;
        pointer-events: none;
    }

    .register-page::after {
        content: '';
        position: absolute;
        bottom: -20%;
        left: -10%;
        width: 500px;
        height: 500px;
        background: radial-gradient(circle, rgba(5, 150, 105, 0.15) 0%, transparent 70%);
        animation: float 25s ease-in-out infinite reverse;
        pointer-events: none;
    }

    .register-card {
        width: 100%;
        max-width: 550px;
        background: var(--glass-bg);
        border-radius: 32px;
        border: 1px solid var(--glass-border);
        backdrop-filter: blur(20px);
        box-shadow: 0 30px 80px rgba(0, 0, 0, 0.12);
        overflow: hidden;
        animation: fadeInUp 0.8s ease-out;
        position: relative;
        z-index: 1;
    }

    .register-header {
        background: linear-gradient(135deg, var(--accent) 0%, var(--primary) 50%, var(--primary-dark) 100%);
        background-size: 200% auto;
        animation: shimmer 6s linear infinite;
        color: white;
        padding: 50px 40px;
        text-align: center;
        position: relative;
    }

    .register-header::before {
        content: '';
        position: absolute;
        top: 50%;
        left: 50%;
        width: 120px;
        height: 120px;
        background: rgba(255, 255, 255, 0.1);
        border-radius: 50%;
        transform: translate(-50%, -50%);
        animation: pulse-ring 3s ease-out infinite;
    }

    .register-icon {
        width: 90px;
        height: 90px;
        background: rgba(255, 255, 255, 0.2);
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        margin: 0 auto 20px;
        position: relative;
        z-index: 1;
        animation: icon-bounce 3s ease-in-out infinite;
    }

    .register-icon i {
        font-size: 2.5rem;
    }

    .register-header h1 {
        font-size: 2rem;
        font-weight: 800;
        margin: 0 0 10px;
        letter-spacing: -0.5px;
    }

    .register-header p {
        opacity: 0.9;
        font-size: 1rem;
        margin: 0;
    }

    .register-body {
        padding: 50px 40px;
    }

    .form-row {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 20px;
    }

    .form-group {
        margin-bottom: 25px;
    }

    .form-label {
        font-weight: 700;
        color: var(--text-dark);
        margin-bottom: 10px;
        display: block;
        font-size: 0.95rem;
    }

    .input-wrapper {
        position: relative;
    }

    .input-wrapper i {
        position: absolute;
        left: 18px;
        top: 50%;
        transform: translateY(-50%);
        color: var(--text-muted);
        font-size: 1.1rem;
        transition: all 0.3s ease;
    }

    .form-control {
        width: 100%;
        padding: 16px 20px 16px 50px;
        border: 2px solid #e5e7eb;
        border-radius: 14px;
        font-size: 1rem;
        transition: all 0.3s ease;
        background: white;
    }

    .form-control:focus {
        border-color: var(--primary);
        box-shadow: 0 0 0 4px rgba(5, 150, 105, 0.15);
        outline: none;
    }

    .form-control:focus ~ i {
        color: var(--primary);
    }

    .btn-register {
        width: 100%;
        padding: 18px 30px;
        background: linear-gradient(135deg, var(--accent) 0%, var(--primary) 100%);
        color: white;
        border: none;
        border-radius: 14px;
        font-size: 1.1rem;
        font-weight: 700;
        cursor: pointer;
        transition: all 0.4s cubic-bezier(0.34, 1.56, 0.64, 1);
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 12px;
        position: relative;
        overflow: hidden;
    }

    .btn-register::before {
        content: '';
        position: absolute;
        top: 0;
        left: -100%;
        width: 100%;
        height: 100%;
        background: linear-gradient(90deg, transparent, rgba(255,255,255,0.3), transparent);
        transition: left 0.5s ease;
    }

    .btn-register:hover {
        transform: translateY(-4px);
        box-shadow: 0 20px 40px rgba(217, 119, 6, 0.4);
    }

    .btn-register:hover::before {
        left: 100%;
    }

    .divider {
        text-align: center;
        margin: 30px 0;
        position: relative;
    }

    .divider::before {
        content: '';
        position: absolute;
        top: 50%;
        left: 0;
        right: 0;
        height: 1px;
        background: linear-gradient(90deg, transparent, #e5e7eb, transparent);
    }

    .divider span {
        background: var(--glass-bg);
        padding: 0 20px;
        color: var(--text-muted);
        font-size: 0.9rem;
        position: relative;
    }

    .login-link {
        text-align: center;
    }

    .login-link p {
        color: var(--text-muted);
        margin: 0;
    }

    .login-link a {
        color: var(--primary);
        text-decoration: none;
        font-weight: 700;
        transition: all 0.3s ease;
        position: relative;
    }

    .login-link a::after {
        content: '';
        position: absolute;
        bottom: -2px;
        left: 0;
        width: 0;
        height: 2px;
        background: var(--accent);
        transition: width 0.3s ease;
    }

    .login-link a:hover {
        color: var(--accent);
    }

    .login-link a:hover::after {
        width: 100%;
    }

    .text-danger {
        color: var(--danger);
        font-size: 0.85rem;
        margin-top: 8px;
        display: block;
    }

    .password-strength {
        margin-top: 10px;
        display: flex;
        gap: 5px;
    }

    .strength-bar {
        flex: 1;
        height: 4px;
        background: #e5e7eb;
        border-radius: 2px;
        transition: all 0.3s ease;
    }

    @@media (max-width: 576px) {
        .register-card { border-radius: 24px; margin: 10px; }
        .register-header, .register-body { padding: 35px 25px; }
        .form-row { grid-template-columns: 1fr; }
    }
</style>

<div class="register-page">
    <div class="register-card">
        <div class="register-header">
            <div class="register-icon">
                <i class="fas fa-user-plus"></i>
            </div>
            <h1>Créer un compte</h1>
            <p>Rejoignez notre communauté d'événements</p>
        </div>

        <div class="register-body">
            <form asp-action="Register" method="post">
                <div class="form-row">
                    <div class="form-group">
                        <label asp-for="FirstName" class="form-label">Prénom</label>
                        <div class="input-wrapper">
                            <input asp-for="FirstName" class="form-control" placeholder="Jean" />
                            <i class="fas fa-user"></i>
                        </div>
                        <span asp-validation-for="FirstName" class="text-danger"></span>
                    </div>

                    <div class="form-group">
                        <label asp-for="LastName" class="form-label">Nom</label>
                        <div class="input-wrapper">
                            <input asp-for="LastName" class="form-control" placeholder="Dupont" />
                            <i class="fas fa-user"></i>
                        </div>
                        <span asp-validation-for="LastName" class="text-danger"></span>
                    </div>
                </div>

                <div class="form-group">
                    <label asp-for="Email" class="form-label">Adresse email</label>
                    <div class="input-wrapper">
                        <input asp-for="Email" type="email" class="form-control" placeholder="votre@email.com" />
                        <i class="fas fa-envelope"></i>
                    </div>
                    <span asp-validation-for="Email" class="text-danger"></span>
                </div>

                <div class="form-group">
                    <label asp-for="Password" class="form-label">Mot de passe</label>
                    <div class="input-wrapper">
                        <input asp-for="Password" type="password" class="form-control" placeholder="Minimum 6 caractères" id="password" />
                        <i class="fas fa-lock"></i>
                    </div>
                    <div class="password-strength">
                        <div class="strength-bar"></div>
                        <div class="strength-bar"></div>
                        <div class="strength-bar"></div>
                        <div class="strength-bar"></div>
                    </div>
                    <span asp-validation-for="Password" class="text-danger"></span>
                </div>

                <div class="form-group">
                    <label asp-for="ConfirmPassword" class="form-label">Confirmer le mot de passe</label>
                    <div class="input-wrapper">
                        <input asp-for="ConfirmPassword" type="password" class="form-control" placeholder="Confirmez votre mot de passe" />
                        <i class="fas fa-lock"></i>
                    </div>
                    <span asp-validation-for="ConfirmPassword" class="text-danger"></span>
                </div>

                @if (!ViewData.ModelState.IsValid)
                {
                    <div style="background: rgba(239, 68, 68, 0.1); color: var(--danger); padding: 16px 20px; border-radius: 12px; margin-bottom: 25px; border: 1px solid rgba(239, 68, 68, 0.2);">
                        <i class="fas fa-exclamation-triangle me-2"></i>
                        <div asp-validation-summary="All"></div>
                    </div>
                }

                <button type="submit" class="btn-register">
                    <i class="fas fa-rocket"></i>
                    Créer mon compte
                </button>
            </form>

            <div class="divider">
                <span>ou</span>
            </div>

            <div class="login-link">
                <p>Déjà inscrit? <a asp-controller="Account" asp-action="Login">Se connecter</a></p>
            </div>
        </div>
    </div>
</div>

<script>
document.getElementById('password')?.addEventListener('input', function(e) {
    const password = e.target.value;
    const bars = document.querySelectorAll('.strength-bar');
    let strength = 0;
    
    if (password.length >= 6) strength++;
    if (password.match(/[a-z]/) && password.match(/[A-Z]/)) strength++;
    if (password.match(/[0-9]/)) strength++;
    if (password.match(/[^a-zA-Z0-9]/)) strength++;
    
    const colors = ['#ef4444', '#f59e0b', '#fbbf24', '#10b981'];
    bars.forEach((bar, i) => {
        bar.style.background = i < strength ? colors[strength - 1] : '#e5e7eb';
    });
});
</script>
