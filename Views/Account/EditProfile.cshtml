@model GestionEvenements.Models.UserProfileEditViewModel
@{
    ViewData["Title"] = "Modifier mon profil";
}

<style>
    :root {
        --primary: #1e40af;
        --accent: #ec4899;
        --success: #10b981;
        --danger: #ef4444;
        --border: #e5e7eb;
    }

    @@keyframes fadeIn {
        from { opacity: 0; transform: translateY(20px); }
        to { opacity: 1; transform: translateY(0); }
    }

    @@keyframes slideInDown {
        from { opacity: 0; transform: translateY(-20px); }
        to { opacity: 1; transform: translateY(0); }
    }

    .edit-container {
        max-width: 650px;
        margin: 0 auto;
        animation: fadeIn 0.6s ease-out;
    }

    .back-link {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        color: var(--primary);
        text-decoration: none;
        font-weight: 600;
        margin-bottom: 25px;
        transition: all 0.3s ease;
    }

    .back-link:hover {
        color: var(--accent);
        transform: translateX(-5px);
    }

    .edit-card {
        background: white;
        border-radius: 16px;
        box-shadow: 0 10px 40px rgba(0, 0, 0, 0.1);
        border: 1px solid var(--border);
        overflow: hidden;
    }

    .edit-header {
        background: linear-gradient(135deg, var(--primary) 0%, var(--accent) 100%);
        color: white;
        padding: 35px 30px;
        text-align: center;
    }

    .edit-header h1 {
        font-size: 1.8rem;
        font-weight: 700;
        margin: 0;
    }

    .edit-header p {
        margin-top: 8px;
        opacity: 0.9;
        font-size: 0.95rem;
    }

    .form-section {
        padding: 40px;
    }

    .section-title {
        font-size: 1.1rem;
        font-weight: 700;
        color: #1f2937;
        margin-bottom: 20px;
        padding-bottom: 12px;
        border-bottom: 2px solid #f3f4f6;
        display: flex;
        align-items: center;
        gap: 10px;
    }

    .section-title i {
        color: var(--primary);
    }

    .form-group {
        margin-bottom: 20px;
    }

    .form-label {
        font-weight: 600;
        color: #1f2937;
        margin-bottom: 8px;
        display: block;
        font-size: 0.95rem;
    }

    .form-control {
        border: 2px solid var(--border);
        border-radius: 10px;
        padding: 12px 16px;
        font-size: 1rem;
        width: 100%;
        transition: all 0.3s ease;
        background: white;
    }

    .form-control:focus {
        border-color: var(--primary);
        box-shadow: 0 0 0 3px rgba(30, 64, 175, 0.1);
        outline: none;
    }

    .form-control:disabled {
        background: #f9fafb;
        color: #6b7280;
    }

    .form-row {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 15px;
    }

    textarea.form-control {
        min-height: 100px;
        resize: vertical;
    }

    .btn-container {
        display: flex;
        gap: 15px;
        margin-top: 30px;
        padding-top: 25px;
        border-top: 1px solid var(--border);
    }

    .btn {
        flex: 1;
        padding: 14px 24px;
        border-radius: 10px;
        font-size: 1rem;
        font-weight: 600;
        cursor: pointer;
        transition: all 0.3s cubic-bezier(0.34, 1.56, 0.64, 1);
        text-decoration: none;
        text-align: center;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 8px;
        border: none;
    }

    .btn-primary {
        background: linear-gradient(135deg, var(--primary) 0%, #1e3a8a 100%);
        color: white;
    }

    .btn-primary:hover {
        transform: translateY(-3px);
        box-shadow: 0 10px 25px rgba(30, 64, 175, 0.4);
    }

    .btn-secondary {
        background: #f3f4f6;
        color: #374151;
        border: 2px solid var(--border);
    }

    .btn-secondary:hover {
        background: #e5e7eb;
        transform: translateY(-2px);
    }

    .text-danger {
        color: var(--danger);
        font-size: 0.85rem;
        margin-top: 5px;
        display: block;
    }

    .alert {
        border-radius: 10px;
        border: none;
        padding: 15px 20px;
        margin-bottom: 25px;
        display: flex;
        align-items: center;
        gap: 12px;
        animation: slideInDown 0.5s ease-out;
    }

    .alert-success {
        background: linear-gradient(135deg, rgba(16, 185, 129, 0.15), rgba(16, 185, 129, 0.08));
        color: var(--success);
        border: 1px solid rgba(16, 185, 129, 0.3);
    }

    .alert-danger {
        background: linear-gradient(135deg, rgba(239, 68, 68, 0.15), rgba(239, 68, 68, 0.08));
        color: var(--danger);
        border: 1px solid rgba(239, 68, 68, 0.3);
    }

    .password-link {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        color: var(--primary);
        text-decoration: none;
        font-weight: 600;
        font-size: 0.95rem;
        margin-top: 15px;
        padding: 12px 20px;
        background: linear-gradient(135deg, rgba(30, 64, 175, 0.08), rgba(236, 72, 153, 0.05));
        border-radius: 10px;
        transition: all 0.3s ease;
    }

    .password-link:hover {
        background: linear-gradient(135deg, rgba(30, 64, 175, 0.15), rgba(236, 72, 153, 0.1));
        transform: translateX(5px);
    }

    .help-text {
        font-size: 0.85rem;
        color: #6b7280;
        margin-top: 5px;
    }

    @@media (max-width: 576px) {
        .edit-container {
            margin: 0 -15px;
        }

        .edit-card {
            border-radius: 0;
        }

        .form-section {
            padding: 25px;
        }

        .form-row {
            grid-template-columns: 1fr;
        }

        .btn-container {
            flex-direction: column;
        }
    }
</style>

<div class="edit-container">
    <a asp-action="Profile" class="back-link">
        <i class="fas fa-arrow-left"></i>Retour au profil
    </a>

    <div class="edit-card">
        <div class="edit-header">
            <h1>
                <i class="fas fa-user-edit me-2"></i>Modifier mon profil
            </h1>
            <p>Mettez à jour vos informations personnelles</p>
        </div>

        <div class="form-section">
            @if (TempData["SuccessMessage"] != null)
            {
                <div class="alert alert-success">
                    <i class="fas fa-check-circle"></i>
                    <span>@TempData["SuccessMessage"]</span>
                </div>
            }

            @if (TempData["ErrorMessage"] != null)
            {
                <div class="alert alert-danger">
                    <i class="fas fa-exclamation-circle"></i>
                    <span>@TempData["ErrorMessage"]</span>
                </div>
            }

            <form asp-action="UpdateProfile" method="post">
                <!-- Informations de base -->
                <h3 class="section-title">
                    <i class="fas fa-id-card"></i>Informations de base
                </h3>

                <div class="form-row">
                    <div class="form-group">
                        <label asp-for="FirstName" class="form-label">Prénom *</label>
                        <input asp-for="FirstName" class="form-control" placeholder="Votre prénom" />
                        <span asp-validation-for="FirstName" class="text-danger"></span>
                    </div>

                    <div class="form-group">
                        <label asp-for="LastName" class="form-label">Nom *</label>
                        <input asp-for="LastName" class="form-control" placeholder="Votre nom" />
                        <span asp-validation-for="LastName" class="text-danger"></span>
                    </div>
                </div>

                <div class="form-group">
                    <label asp-for="Email" class="form-label">Adresse email *</label>
                    <input asp-for="Email" type="email" class="form-control" placeholder="votre@email.com" />
                    <span asp-validation-for="Email" class="text-danger"></span>
                </div>

                <div class="form-group">
                    <label asp-for="PhoneNumber" class="form-label">Numéro de téléphone</label>
                    <input asp-for="PhoneNumber" type="tel" class="form-control" placeholder="+212 6XX XXX XXX" />
                    <span asp-validation-for="PhoneNumber" class="text-danger"></span>
                </div>

                <!-- Informations supplémentaires -->
                <h3 class="section-title" style="margin-top: 35px;">
                    <i class="fas fa-info-circle"></i>Informations supplémentaires
                </h3>

                <div class="form-group">
                    <label asp-for="Bio" class="form-label">Biographie</label>
                    <textarea asp-for="Bio" class="form-control" placeholder="Parlez-nous un peu de vous..."></textarea>
                    <span class="help-text">Maximum 500 caractères</span>
                    <span asp-validation-for="Bio" class="text-danger"></span>
                </div>

                <div class="form-row">
                    <div class="form-group">
                        <label asp-for="Ville" class="form-label">Ville</label>
                        <input asp-for="Ville" class="form-control" placeholder="Ex: Casablanca" />
                        <span asp-validation-for="Ville" class="text-danger"></span>
                    </div>

                    <div class="form-group">
                        <label asp-for="Pays" class="form-label">Pays</label>
                        <input asp-for="Pays" class="form-control" placeholder="Ex: Maroc" />
                        <span asp-validation-for="Pays" class="text-danger"></span>
                    </div>
                </div>

                <div class="form-group">
                    <label asp-for="DateNaissance" class="form-label">Date de naissance</label>
                    <input asp-for="DateNaissance" type="date" class="form-control" />
                    <span asp-validation-for="DateNaissance" class="text-danger"></span>
                </div>

                <!-- Mot de passe -->
                <h3 class="section-title" style="margin-top: 35px;">
                    <i class="fas fa-lock"></i>Sécurité
                </h3>

                <p style="color: #6b7280; margin-bottom: 15px;">
                    Pour modifier votre mot de passe, utilisez le lien ci-dessous.
                </p>

                <a asp-action="ChangePassword" class="password-link">
                    <i class="fas fa-key"></i>Changer mon mot de passe
                    <i class="fas fa-chevron-right" style="margin-left: auto;"></i>
                </a>

                @if (!ViewData.ModelState.IsValid)
                {
                    <div asp-validation-summary="All" class="text-danger" style="margin-top: 20px;"></div>
                }

                <div class="btn-container">
                    <a asp-action="Profile" class="btn btn-secondary">
                        <i class="fas fa-times"></i>Annuler
                    </a>
                    <button type="submit" class="btn btn-primary">
                        <i class="fas fa-save"></i>Enregistrer les modifications
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>