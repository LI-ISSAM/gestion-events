@using GestionEvenements.Models
@using Microsoft.AspNetCore.Identity
@inject UserManager<ApplicationUser> UserManager
@model Event

@{
    ViewData["Title"] = @Model.Titre;
    var currentUser = await UserManager.GetUserAsync(User);
    var isAdmin = User.IsInRole("Admin");
    var isRegistered = Model.Inscriptions.Any(r => r.UserId == currentUser?.Id);
}

@{
    var successMessage = TempData["SuccessMessage"] as string;
    var errorMessage = TempData["ErrorMessage"] as string;
}

<style>
    :root {
        --primary: #0f766e;
        --accent: #d946ef;
        --success: #059669;
        --danger: #dc2626;
        --light-bg: #f0fdfa;
        --card-bg: rgba(255, 255, 255, 0.8);
        --glass: rgba(255, 255, 255, 0.7);
    }

    * {
        box-sizing: border-box;
    }

    body {
        background: linear-gradient(135deg, var(--light-bg) 0%, #fef3f2 100%);
        min-height: 100vh;
    }

    /* Added premium animations and keyframes */
    @@keyframes fadeInDown {
        from {
            opacity: 0;
            transform: translateY(-30px);
        }
        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    @@keyframes fadeInUp {
        from {
            opacity: 0;
            transform: translateY(30px);
        }
        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    @@keyframes slideInLeft {
        from {
            opacity: 0;
            transform: translateX(-50px);
        }
        to {
            opacity: 1;
            transform: translateX(0);
        }
    }

    @@keyframes slideInRight {
        from {
            opacity: 0;
            transform: translateX(50px);
        }
        to {
            opacity: 1;
            transform: translateX(0);
        }
    }

    @@keyframes pulse {
        0%, 100% { opacity: 1; }
        50% { opacity: 0.7; }
    }

    @@keyframes float {
        0%, 100% { transform: translateY(0px); }
        50% { transform: translateY(-10px); }
    }

    @@keyframes shimmer {
        0% { background-position: -1000px 0; }
        100% { background-position: 1000px 0; }
    }

    @@keyframes glow {
        0%, 100% { box-shadow: 0 0 20px rgba(15, 118, 110, 0.3); }
        50% { box-shadow: 0 0 40px rgba(15, 118, 110, 0.6); }
    }

    .details-container {
        animation: fadeInDown 0.8s ease-out;
        padding: 40px 20px;
        max-width: 1400px;
        margin: 0 auto;
    }

    /* Enhanced breadcrumb with modern styling */
    .breadcrumb-nav {
        display: flex;
        gap: 15px;
        margin-bottom: 50px;
        animation: slideInLeft 0.8s ease-out;
        flex-wrap: wrap;
    }

    .breadcrumb-nav a,
    .breadcrumb-nav span {
        display: flex;
        align-items: center;
        gap: 8px;
        font-size: 0.95rem;
        font-weight: 500;
        color: var(--primary);
        text-decoration: none;
        transition: all 0.3s cubic-bezier(0.34, 1.56, 0.64, 1);
        padding: 8px 12px;
        border-radius: 8px;
    }

    .breadcrumb-nav a:hover {
        background: rgba(15, 118, 110, 0.1);
        transform: translateX(5px);
    }

  .details-hero {
    border-radius: 24px;
    overflow: hidden;
    margin-bottom: 50px;
    animation: fadeInUp 1s ease-out;
    position: relative;
    max-height: 500px; /* Hauteur maximum au lieu de fixe */
    box-shadow: 0 25px 50px rgba(0, 0, 0, 0.15);
}

.details-hero img {
    width: 100%;
    height: 100%;
    max-height: 500px; 
    object-fit: cover; 
    object-position: center; 
    display: block; 
    transition: transform 0.6s cubic-bezier(0.34, 1.56, 0.64, 1);
}

.details-hero:hover img {
    transform: scale(1.02); 
}

@@media (max-width: 768px) {
    .details-hero {
        max-height: 300px;
        border-radius: 16px;
    }
    
    .details-hero img {
        max-height: 300px;
    }
}

    /* Main content grid with improved layout */
    .details-grid {
        display: grid;
        grid-template-columns: 2fr 1fr;
        gap: 50px;
        align-items: start;
    }

    .details-main {
        background: var(--card-bg);
        backdrop-filter: blur(10px);
        border-radius: 20px;
        padding: 50px;
        box-shadow: 0 8px 32px rgba(0, 0, 0, 0.08);
        border: 1px solid rgba(255, 255, 255, 0.5);
        animation: slideInLeft 1s ease-out;
    }

    .details-title {
        font-size: 3rem;
        font-weight: 800;
        background: linear-gradient(135deg, var(--primary) 0%, var(--accent) 100%);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
        margin-bottom: 25px;
        line-height: 1.2;
        animation: fadeInUp 1.2s ease-out;
    }

    .details-section {
        margin-bottom: 45px;
        padding-bottom: 45px;
        border-bottom: 2px solid rgba(15, 118, 110, 0.1);
        animation: fadeInUp 1.4s ease-out;
    }

    .details-section:last-child {
        border-bottom: none;
    }

    .section-title {
        font-size: 1.4rem;
        font-weight: 700;
        color: var(--primary);
        margin-bottom: 20px;
        display: flex;
        align-items: center;
        gap: 12px;
        transition: all 0.3s ease;
    }

    .section-title i {
        font-size: 1.5rem;
        transition: all 0.3s cubic-bezier(0.34, 1.56, 0.64, 1);
    }

    .section-title:hover i {
        transform: rotate(360deg) scale(1.2);
        color: var(--accent);
    }

    .details-description {
        color: #4b5563;
        line-height: 1.9;
        font-size: 1.05rem;
    }

    /* Enhanced info items with icons */
    .info-item {
        display: flex;
        align-items: flex-start;
        gap: 20px;
        margin-bottom: 20px;
        padding: 20px;
        background: linear-gradient(135deg, rgba(15, 118, 110, 0.05) 0%, rgba(217, 70, 239, 0.02) 100%);
        border-radius: 15px;
        border-left: 4px solid var(--primary);
        transition: all 0.3s cubic-bezier(0.34, 1.56, 0.64, 1);
        animation: fadeInUp 1.4s ease-out;
    }

    .info-item:hover {
        transform: translateX(10px);
        box-shadow: 0 10px 30px rgba(15, 118, 110, 0.15);
        background: linear-gradient(135deg, rgba(15, 118, 110, 0.1) 0%, rgba(217, 70, 239, 0.05) 100%);
    }

    .info-item i {
        color: var(--accent);
        font-size: 1.4rem;
        width: 30px;
        text-align: center;
        flex-shrink: 0;
        margin-top: 5px;
        transition: all 0.3s ease;
    }

    .info-item:hover i {
        transform: scale(1.3) rotate(10deg);
    }

    .info-label {
        font-weight: 600;
        color: var(--primary);
        font-size: 0.95rem;
        text-transform: uppercase;
        letter-spacing: 0.5px;
    }

    .info-value {
        color: #2d3748;
        margin-top: 5px;
        font-size: 1.05rem;
    }

    .details-sidebar {
        position: sticky;
        top: 100px;
    }

    /* Premium sidebar cards with glass effect */
    .sidebar-card {
        background: var(--glass);
        backdrop-filter: blur(15px);
        border-radius: 20px;
        padding: 40px;
        box-shadow: 0 8px 32px rgba(0, 0, 0, 0.08);
        border: 1px solid rgba(255, 255, 255, 0.6);
        margin-bottom: 25px;
        animation: slideInRight 1s ease-out;
        transition: all 0.3s ease;
    }

    .sidebar-card:hover {
        box-shadow: 0 15px 50px rgba(15, 118, 110, 0.2);
        transform: translateY(-5px);
    }

    .price-section {
        text-align: center;
    }

    .price-label {
        color: #6b7280;
        font-size: 1rem;
        margin-bottom: 15px;
        text-transform: uppercase;
        letter-spacing: 1px;
        font-weight: 600;
    }

    .price-value {
        font-size: 3.5rem;
        font-weight: 900;
        background: linear-gradient(135deg, var(--primary) 0%, var(--accent) 100%);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
        margin-bottom: 30px;
        animation: pulse 2s ease-in-out infinite;
    }

    /* Enhanced action buttons with gradients and animations */
    .btn-action {
        width: 100%;
        padding: 16px 24px;
        border: none;
        border-radius: 12px;
        font-size: 1.05rem;
        font-weight: 700;
        cursor: pointer;
        transition: all 0.3s cubic-bezier(0.34, 1.56, 0.64, 1);
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 12px;
        margin-bottom: 15px;
        position: relative;
        overflow: hidden;
        text-decoration: none;
    }

    .btn-action::before {
        content: '';
        position: absolute;
        top: 50%;
        left: 50%;
        width: 0;
        height: 0;
        border-radius: 50%;
        background: rgba(255, 255, 255, 0.3);
        transform: translate(-50%, -50%);
        transition: width 0.6s ease, height 0.6s ease;
    }

    .btn-action:active::before {
        width: 300px;
        height: 300px;
    }

    .btn-primary {
        background: linear-gradient(135deg, var(--primary) 0%, #0d9488 100%);
        color: white;
        box-shadow: 0 10px 30px rgba(15, 118, 110, 0.3);
    }

    .btn-primary:hover {
        transform: translateY(-4px);
        box-shadow: 0 20px 50px rgba(15, 118, 110, 0.5);
    }

    .btn-danger {
        background: linear-gradient(135deg, var(--danger) 0%, #b91c1c 100%);
        color: white;
        box-shadow: 0 10px 30px rgba(220, 38, 38, 0.3);
    }

    .btn-danger:hover {
        transform: translateY(-4px);
        box-shadow: 0 20px 50px rgba(220, 38, 38, 0.5);
    }

    /* Status badges with enhanced styling */
    .status-badge {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        padding: 12px 24px;
        border-radius: 25px;
        font-size: 0.95rem;
        font-weight: 700;
        margin-bottom: 20px;
        animation: fadeInUp 1.2s ease-out;
    }

    .status-available {
        background: linear-gradient(135deg, rgba(5, 150, 105, 0.15) 0%, rgba(5, 150, 105, 0.05) 100%);
        color: var(--success);
        border: 2px solid var(--success);
    }

    .status-registered {
        background: linear-gradient(135deg, rgba(15, 118, 110, 0.15) 0%, rgba(15, 118, 110, 0.05) 100%);
        color: var(--primary);
        border: 2px solid var(--primary);
    }

    .status-pending {
        background: linear-gradient(135deg, rgba(245, 158, 11, 0.12) 0%, rgba(245, 158, 11, 0.05) 100%);
        color: #b45309; /* amber-700 */
        border: 2px solid #f59e0b; /* amber-500 */
    }

    .status-rejected {
        background: linear-gradient(135deg, rgba(220, 38, 38, 0.12) 0%, rgba(220, 38, 38, 0.05) 100%);
        color: var(--danger);
        border: 2px solid var(--danger);
    }

    /* Admin actions container */
    .admin-actions {
        display: flex;
        gap: 12px;
        flex-direction: column;
    }

    .admin-actions .btn-action {
        margin-bottom: 0;
    }

    /* Registrations list with improved styling */
    .registrations-list {
        margin-top: 25px;
        padding-top: 25px;
        border-top: 2px solid rgba(15, 118, 110, 0.1);
    }

    .registration-item {
        padding: 20px;
        display: flex;
        align-items: center;
        gap: 18px;
        border-bottom: 1px solid rgba(15, 118, 110, 0.08);
        background: linear-gradient(135deg, rgba(240, 253, 250, 0.5) 0%, rgba(245, 245, 244, 0.3) 100%);
        border-radius: 12px;
        margin-bottom: 12px;
        transition: all 0.3s cubic-bezier(0.34, 1.56, 0.64, 1);
        animation: fadeInUp 1.5s ease-out;
    }

    .registration-item:hover {
        background: linear-gradient(135deg, rgba(15, 118, 110, 0.08) 0%, rgba(217, 70, 239, 0.04) 100%);
        transform: translateX(8px);
        box-shadow: 0 8px 25px rgba(15, 118, 110, 0.1);
    }

    .registration-avatar {
        width: 50px;
        height: 50px;
        border-radius: 50%;
        background: linear-gradient(135deg, var(--primary) 0%, var(--accent) 100%);
        color: white;
        display: flex;
        align-items: center;
        justify-content: center;
        font-weight: 700;
        flex-shrink: 0;
        animation: float 3s ease-in-out infinite;
        box-shadow: 0 5px 15px rgba(15, 118, 110, 0.3);
    }

    /* Comments section with glassmorphism */
    .comments-section {
        background: var(--card-bg);
        backdrop-filter: blur(10px);
        border-radius: 20px;
        padding: 50px;
        box-shadow: 0 8px 32px rgba(0, 0, 0, 0.08);
        border: 1px solid rgba(255, 255, 255, 0.5);
        margin-top: 50px;
        animation: fadeInUp 1.6s ease-out;
    }

    .comment-form {
        background: linear-gradient(135deg, rgba(240, 253, 250, 0.8) 0%, rgba(245, 245, 244, 0.6) 100%);
        border-radius: 16px;
        padding: 30px;
        margin-bottom: 40px;
        border: 2px solid rgba(15, 118, 110, 0.15);
        animation: slideInLeft 1.6s ease-out;
    }

    .form-group {
        margin-bottom: 25px;
    }

    .form-group label {
        display: block;
        margin-bottom: 10px;
        font-weight: 700;
        color: var(--primary);
        text-transform: uppercase;
        font-size: 0.9rem;
        letter-spacing: 0.5px;
    }

    .form-group textarea {
        width: 100%;
        padding: 15px;
        border: 2px solid rgba(15, 118, 110, 0.2);
        border-radius: 12px;
        font-family: inherit;
        font-size: 1rem;
        resize: vertical;
        min-height: 120px;
        transition: all 0.3s ease;
        background: rgba(255, 255, 255, 0.7);
    }

    .form-group textarea:focus {
        outline: none;
        border-color: var(--primary);
        box-shadow: 0 0 0 4px rgba(15, 118, 110, 0.1);
        background: white;
    }

    /* Star rating with smooth animations */
    .star-rating {
        display: flex;
        gap: 10px;
        align-items: center;
        flex-direction: row-reverse;
        justify-content: flex-end;
    }

    .star-rating input[type="radio"] {
        display: none;
    }

    .star-rating label {
        margin: 0;
        font-size: 2rem;
        color: #d1d5db;
        cursor: pointer;
        transition: all 0.2s cubic-bezier(0.34, 1.56, 0.64, 1);
        padding: 5px;
    }

    .star-rating input[type="radio"]:checked ~ label,
    .star-rating label:hover,
    .star-rating label:hover ~ label {
        color: #f59e0b;
        transform: scale(1.3) rotate(15deg);
        filter: drop-shadow(0 0 10px rgba(245, 158, 11, 0.5));
    }

    .btn-submit {
        background: linear-gradient(135deg, var(--primary) 0%, var(--accent) 100%);
        color: white;
        padding: 14px 32px;
        border: none;
        border-radius: 12px;
        font-weight: 700;
        cursor: pointer;
        transition: all 0.3s cubic-bezier(0.34, 1.56, 0.64, 1);
        display: inline-flex;
        align-items: center;
        gap: 10px;
        box-shadow: 0 10px 30px rgba(15, 118, 110, 0.3);
    }

    .btn-submit:hover {
        transform: translateY(-4px);
        box-shadow: 0 20px 50px rgba(15, 118, 110, 0.5);
    }

    .comments-list {
        margin-top: 40px;
    }

    .comment-item {
        background: linear-gradient(135deg, rgba(240, 253, 250, 0.6) 0%, rgba(245, 245, 244, 0.4) 100%);
        border-radius: 16px;
        padding: 25px;
        margin-bottom: 25px;
        border-left: 5px solid var(--primary);
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        gap: 20px;
        transition: all 0.3s cubic-bezier(0.34, 1.56, 0.64, 1);
        animation: fadeInUp 1.7s ease-out;
    }

    .comment-item:hover {
        transform: translateX(10px);
        box-shadow: 0 15px 40px rgba(15, 118, 110, 0.15);
        background: linear-gradient(135deg, rgba(15, 118, 110, 0.08) 0%, rgba(217, 70, 239, 0.04) 100%);
    }

    .comment-author {
        font-weight: 800;
        color: var(--primary);
        margin-bottom: 8px;
        font-size: 1.1rem;
    }

    .comment-rating {
        color: #f59e0b;
        font-size: 1rem;
        margin-bottom: 12px;
    }

    .comment-rating i {
        margin-right: 4px;
    }

    .comment-content {
        color: #374151;
        line-height: 1.7;
        margin-bottom: 12px;
        font-size: 1rem;
    }

    .comment-date {
        font-size: 0.9rem;
        color: #9ca3af;
        font-weight: 500;
    }

    .comment-actions {
        display: flex;
        gap: 12px;
    }

    .comment-delete-btn {
        background: transparent;
        border: none;
        color: var(--danger);
        cursor: pointer;
        font-weight: 700;
        font-size: 0.9rem;
        transition: all 0.2s ease;
    }

    .comment-delete-btn:hover {
        color: #dc2626;
        transform: scale(1.1);
    }

    .empty-comments {
        text-align: center;
        padding: 50px 20px;
        color: #9ca3af;
        font-size: 1.1rem;
    }

    .no-login-message {
        background: linear-gradient(135deg, rgba(15, 118, 110, 0.1) 0%, rgba(217, 70, 239, 0.05) 100%);
        border: 2px solid var(--primary);
        border-radius: 12px;
        padding: 25px;
        text-align: center;
        color: var(--primary);
        animation: fadeInUp 1.4s ease-out;
    }

    .no-login-message a {
        color: var(--accent);
        font-weight: 700;
        text-decoration: none;
        transition: all 0.3s ease;
    }

    .no-login-message a:hover {
        text-decoration: underline;
        color: var(--primary);
    }

    .alert {
        border-radius: 12px;
        padding: 20px;
        margin-bottom: 30px;
        animation: slideInDown 0.6s ease-out;
        border: 2px solid;
    }

    .alert-success {
        background: linear-gradient(135deg, rgba(5, 150, 105, 0.1) 0%, rgba(5, 150, 105, 0.05) 100%);
        color: var(--success);
        border-color: var(--success);
    }

    .alert-danger {
        background: linear-gradient(135deg, rgba(220, 38, 38, 0.1) 0%, rgba(220, 38, 38, 0.05) 100%);
        color: var(--danger);
        border-color: var(--danger);
    }

    @@media (max-width: 768px) {
        .details-hero {
            height: 300px;
            margin-bottom: 30px;
        }

        .details-grid {
            grid-template-columns: 1fr;
            gap: 30px;
        }

        .details-main {
            padding: 25px;
        }

        .details-title {
            font-size: 2rem;
        }

        .details-sidebar {
            position: static;
        }

        .price-value {
            font-size: 2.5rem;
        }

        .comment-item {
            flex-direction: column;
        }

        .comments-section {
            padding: 25px;
        }
    }
</style>

@if (!string.IsNullOrEmpty(successMessage))
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        <i class="fas fa-check-circle"></i> @successMessage
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

@if (!string.IsNullOrEmpty(errorMessage))
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        <i class="fas fa-exclamation-circle"></i> @errorMessage
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="details-container">
    <div class="breadcrumb-nav">
        <a asp-controller="Home" asp-action="Index">
            <i class="fas fa-home"></i> Accueil
        </a>
        <span>/</span>
        <a asp-controller="Event" asp-action="Index">
            <i class="fas fa-calendar-alt"></i> Événements
        </a>
        <span>/</span>
        <span>@Model.Titre</span>
    </div>

    <div class="details-hero">
        <img src="@(@Model.ImageUrl ?? "/placeholder.svg?height=200&width=400")" alt="@Model.Titre" />
    </div>

    <div class="details-grid">
        <div class="details-main">
            <h1 class="details-title">@Model.Titre</h1>

            @if (!isAdmin)
            {
                var userStatus = ViewBag.UserRegistrationStatus as string;
                if (!string.IsNullOrEmpty(userStatus))
                {
                    if (userStatus == "En attente")
                    {
                        <div class="status-badge status-pending">
                            <i class="fas fa-clock"></i> En attente
                        </div>
                    }
                    else if (userStatus == "Confirmée")
                    {
                        <div class="status-badge status-registered">
                            <i class="fas fa-check-circle"></i> Confirmée
                        </div>
                    }
                    else if (userStatus == "Rejetée" || userStatus == "Rejetee")
                    {
                        <div class="status-badge status-rejected">
                            <i class="fas fa-times-circle"></i> Rejetée
                        </div>
                    }
                    else
                    {
                        <div class="status-badge status-registered">
                            <i class="fas fa-check-circle"></i> @userStatus
                        </div>
                    }
                }
                else
                {
                    <div class="status-badge status-available">
                        <i class="fas fa-check-circle"></i> Disponible
                    </div>
                }
            }

            <div class="details-section">
                <h3 class="section-title">
                    <i class="fas fa-align-left"></i> À propos
                </h3>
                <p class="details-description">@Model.Description</p>
            </div>

            <div class="details-section">
                <h3 class="section-title">
                    <i class="fas fa-info-circle"></i> Détails
                </h3>
                <div class="info-item">
                    <i class="fas fa-map-marker-alt"></i>
                    <div class="info-content">
                        <div class="info-label">Lieu</div>
                        <div class="info-value">@Model.Lieu</div>
                    </div>
                </div>
                <div class="info-item">
                    <i class="fas fa-calendar-days"></i>
                    <div class="info-content">
                        <div class="info-label">Date</div>
                        <div class="info-value">@Model.DateEvent.ToString("dddd dd MMMM yyyy")</div>
                    </div>
                </div>
                <div class="info-item">
                    <i class="fas fa-clock"></i>
                    <div class="info-content">
                        <div class="info-label">Heure</div>
                        <div class="info-value">@Model.DateEvent.ToString("HH:mm")</div>
                    </div>
                </div>
            </div>

            @if (isAdmin)
            {
                <div class="details-section">
                    <h3 class="section-title">
                        <i class="fas fa-users"></i> Inscriptions (@Model.Inscriptions.Count)
                    </h3>
                    @if (Model.Inscriptions.Count > 0)
                    {
                        <div class="registrations-list">
                            @foreach (var reg in Model.Inscriptions)
                            {
                                var initials = $"{reg.User.LastName?.FirstOrDefault() ?? 'U'}{reg.User.FirstName?.FirstOrDefault() ?? 'U'}".ToUpper();
                                <div class="registration-item">
                                    <div class="registration-avatar">@initials</div>
                                    <div style="flex: 1;">
                                        <strong>@reg.User.LastName @reg.User.FirstName</strong><br />
                                        <small style="color: #6b7280;">@reg.User.Email</small><br />
                                        <small style="color: #9ca3af;">Inscrit le @reg.DateInscription.ToString("dd/MM/yyyy à HH:mm")</small>
                                        <div style="margin-top:6px;">
                                            @if (reg.Statut == "Confirmée")
                                            {
                                                <span class="status-badge status-registered">Confirmée</span>
                                            }
                                            else if (reg.Statut == "En attente")
                                            {
                                                <span class="status-badge status-pending">En attente</span>
                                            }
                                            else if (reg.Statut == "Rejetée" || reg.Statut == "Rejetee")
                                            {
                                                <span class="status-badge status-rejected">Rejetée</span>
                                            }
                                            else
                                            {
                                                <span class="status-badge">@reg.Statut</span>
                                            }
                                        </div>
                                    </div>
                                </div>
                            }
                        </div>
                    }
                    else
                    {
                        <p style="color: #9ca3af;">Aucune inscription pour le moment.</p>
                    }
                </div>
            }
        </div>

        <div class="details-sidebar">
            <div class="sidebar-card price-section">
                <div class="price-label">Prix d'entrée</div>
                <div class="price-value">@Model.Prix.ToString("0.00") DH</div>

                @if (!isAdmin)
                {
                    @if (isRegistered)
                    {
                        <form asp-action="Unregister" method="post">
                            <input type="hidden" name="eventId" value="@Model.Id" />
                            <button type="submit" class="btn-action btn-danger">
                                <i class="fas fa-times-circle"></i> Se désinscrire
                            </button>
                        </form>
                    }
                    else
                    {
                        <form asp-action="Register" method="post">
                            <input type="hidden" name="eventId" value="@Model.Id" />
                            <button type="submit" class="btn-action btn-primary">
                                <i class="fas fa-ticket-alt"></i> S'inscrire maintenant
                            </button>
                        </form>
                    }
                }
            </div>

            @if (isAdmin)
            {
                <div class="sidebar-card">
                    <div class="admin-actions">
                        <a asp-action="Inscriptions" asp-route-eventId="@Model.Id" class="btn-action btn-primary">
                            <i class="fas fa-list"></i> Gérer les inscriptions
                        </a>
                        <a asp-action="Edit" asp-route-id="@Model.Id" class="btn-action btn-primary">
                            <i class="fas fa-edit"></i> Modifier
                        </a>
                        <a asp-action="Delete" asp-route-id="@Model.Id" class="btn-action btn-danger">
                            <i class="fas fa-trash"></i> Supprimer
                        </a>
                    </div>
                </div>
            }
        </div>
    </div>

    <div class="comments-section">
        <h3 class="section-title">
            <i class="fas fa-comments"></i> Avis et commentaires (@Model.Commentaires.Count)
        </h3>

        @if (User.Identity.IsAuthenticated)
        {
            <form asp-action="PostComment" method="post" class="comment-form">
                <input type="hidden" name="eventId" value="@Model.Id" />
                
                <div class="form-group">
                    <label>Votre avis</label>
                    <textarea name="Texte" placeholder="Partagez votre expérience sur cet événement..." required></textarea>
                </div>

                <div class="form-group">
                    <label>Note</label>
                    <div class="star-rating">
                        <input type="radio" id="star5" name="note" value="5" required>
                        <label for="star5" title="5 étoiles"><i class="fas fa-star"></i></label>

                        <input type="radio" id="star4" name="note" value="4">
                        <label for="star4" title="4 étoiles"><i class="fas fa-star"></i></label>

                        <input type="radio" id="star3" name="note" value="3">
                        <label for="star3" title="3 étoiles"><i class="fas fa-star"></i></label>

                        <input type="radio" id="star2" name="note" value="2">
                        <label for="star2" title="2 étoiles"><i class="fas fa-star"></i></label>

                        <input type="radio" id="star1" name="note" value="1">
                        <label for="star1" title="1 étoile"><i class="fas fa-star"></i></label>
                    </div>
                </div>

                <button type="submit" class="btn-submit">
                    <i class="fas fa-paper-plane"></i>Publier mon avis
                </button>
            </form>
        }
        else
        {
            <div class="no-login-message">
                <i class="fas fa-info-circle"></i>
                <a asp-controller="Account" asp-action="Login">Connectez-vous</a> pour laisser un avis
            </div>
        }

        @if (Model.Commentaires.Any())
        {
            <div class="comments-list">
                @foreach (var comment in Model.Commentaires.OrderByDescending(c => c.DateCreation))
                {
                    <div class="comment-item">
                        <div style="flex: 1;">
                            <div class="comment-author">
                                <i class="fas fa-user-circle"></i> @comment.User?.FirstName @comment.User?.LastName
                            </div>
                            <div class="comment-rating">
                                @for (int i = 0; i < comment.Note; i++)
                                {
                                    <i class="fas fa-star"></i>
                                }
                            </div>
                            <div class="comment-content">
                                @comment.Texte
                            </div>
                            <div class="comment-date">
                                <i class="fas fa-calendar"></i> @comment.DateCreation.ToString("dd/MM/yyyy à HH:mm")
                            </div>
                        </div>
                        @if (comment.UserId == currentUser?.Id || isAdmin)
                        {
                            <div class="comment-actions">
                                <form asp-action="DeleteComment" method="post" style="display: inline;">
                                    <input type="hidden" name="commentId" value="@comment.Id" />
                                    <input type="hidden" name="eventId" value="@Model.Id" />  
                                    <button type="submit" class="comment-delete-btn" onclick="return confirm('Êtes-vous sûr ?')">
                                        <i class="fas fa-trash"></i> Supprimer
                                    </button>
                                </form>
                            </div>
                        }
                    </div>
                }
            </div>
        }
        else
        {
            <div class="empty-comments">
                <i class="fas fa-inbox"></i><br>
                Aucun avis pour le moment. Soyez le premier à laisser un avis !
            </div>
        }
    </div>
</div>
