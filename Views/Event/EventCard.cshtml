@model Event;

<style>
    .event-card {
        background: white;
        border-radius: 12px;
        overflow: hidden;
        box-shadow: 0 4px 15px rgba(0,0,0,0.08);
        transition: all 0.3s ease;
        border: 1px solid #e5e7eb;
        display: flex;
        flex-direction: column;
        height: 100%;
    }

    .event-card:hover {
        transform: translateY(-8px);
        box-shadow: 0 15px 40px rgba(0,0,0,0.15);
        border-color: #1e40af;
    }

    .event-image {
        width: 100%;
        height: 200px;
        object-fit: cover;
        position: relative;
    }

    .event-status-badge {
        position: absolute;
        top: 10px;
        right: 10px;
        padding: 8px 12px;
        border-radius: 20px;
        font-size: 0.75rem;
        font-weight: 700;
    }

    .badge-terminated {
        background: #10b981;
        color: white;
    }

    .badge-cancelled {
        background: #ef4444;
        color: white;
    }

    .badge-upcoming {
        background: #3b82f6;
        color: white;
    }

    .event-content {
        padding: 20px;
        flex: 1;
    }

    .event-title {
        font-size: 1.2rem;
        font-weight: 700;
        color: #1f2937;
        margin-bottom: 10px;
    }

    .event-meta {
        display: flex;
        flex-direction: column;
        gap: 8px;
        color: #6b7280;
        font-size: 0.9rem;
        margin-bottom: 15px;
    }

    .event-rating {
        display: flex;
        align-items: center;
        gap: 8px;
        color: #fbbf24;
    }

    .event-footer {
        padding-top: 15px;
        border-top: 1px solid #e5e7eb;
        display: flex;
        justify-content: space-between;
        align-items: center;
    }

    .event-price {
        font-size: 1.5rem;
        font-weight: 700;
        color: #1e40af;
    }

    .btn-small {
        padding: 8px 16px;
        border-radius: 6px;
        text-decoration: none;
        font-size: 0.85rem;
        font-weight: 600;
        transition: all 0.3s ease;
    }

    .btn-primary {
        background: #1e40af;
        color: white;
    }

    .btn-primary:hover {
        background: #1e3a8a;
    }
</style>

<div class="event-card">
    <div style="position: relative;">
        <img src="@(Model.ImageUrl ?? "/placeholder.svg?height=200&width=400")" alt="@Model.Titre" class="event-image" />
        @if (Model.EstAnnule)
        {
            <span class="event-status-badge badge-cancelled">Annulé</span>
        }
        else if (Model.DateEvent < DateTime.Now)
        {
            <span class="event-status-badge badge-terminated">Terminé</span>
        }
        else
        {
            <span class="event-status-badge badge-upcoming">À venir</span>
        }
    </div>

    <div class="event-content">
        <h3 class="event-title">@Model.Titre</h3>
        <div class="event-meta">
            <div>
                <i class="fas fa-map-marker-alt me-1"></i>@Model.Lieu
            </div>
            <div>
                <i class="fas fa-calendar me-1"></i>@Model.DateEvent.ToString("dd/MM/yyyy HH:mm")
            </div>
            @if (Model.Statistiques?.AverageRating > 0)
            {
                <div class="event-rating">
                    @for (int i = 1; i <= 5; i++)
                    {
                        <i class="fas fa-star@(i <= Model.Statistiques.AverageRating ? "" : "-o")"></i>
                    }
                    <span style="color: #6b7280;">(@(Model.Statistiques.TotalComments))</span>
                </div>
            }
        </div>
    </div>

    <div class="event-footer">
        <div class="event-price">@Model.Prix.ToString("0.00") DH</div>
        <a asp-action="Details" asp-route-id="@Model.Id" class="btn-small btn-primary">
            <i class="fas fa-arrow-right"></i> Détails
        </a>
    </div>
</div>
