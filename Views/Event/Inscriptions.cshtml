@using GestionEvenements.Models
@model List<Inscription>

@{
    ViewData["Title"] = "Gestion des Inscriptions";
}

@Html.AntiForgeryToken()

<style>
    :root {
        --primary: #059669;
        --primary-dark: #047857;
        --accent: #f59e0b;
        --secondary: #0d9488;
        --success: #22c55e;
        --warning: #f59e0b;
        --danger: #ef4444;
        --text-dark: #0f172a;
        --text-muted: #64748b;
    }

    @@keyframes fadeInUp { from { opacity: 0; transform: translateY(30px); } to { opacity: 1; transform: translateY(0); } }
    @@keyframes slideInRight { from { opacity: 0; transform: translateX(30px); } to { opacity: 1; transform: translateX(0); } }
    @@keyframes pulse-ring { 0% { transform: scale(0.9); opacity: 1; } 100% { transform: scale(1.3); opacity: 0; } }
    @@keyframes shimmer { 0% { background-position: -200% 0; } 100% { background-position: 200% 0; } }

    .inscriptions-container { padding: 20px 0; }

    .inscriptions-header { margin-bottom: 40px; animation: fadeInUp 0.6s ease-out; }

    .breadcrumb-nav {
        display: flex;
        align-items: center;
        gap: 8px;
        margin-bottom: 24px;
        font-size: 0.9rem;
    }
    .breadcrumb-nav a {
        color: var(--primary);
        text-decoration: none;
        font-weight: 600;
        transition: all 0.3s ease;
        display: flex;
        align-items: center;
        gap: 6px;
    }
    .breadcrumb-nav a:hover { color: var(--accent); }
    .breadcrumb-nav span { color: var(--text-muted); }

    .header-content {
        background: white;
        border-radius: 24px;
        padding: 36px;
        box-shadow: 0 4px 20px rgba(0, 0, 0, 0.04);
        border: 1px solid rgba(0, 0, 0, 0.04);
        position: relative;
        overflow: hidden;
    }
    .header-content::before {
        content: '';
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 4px;
        background: linear-gradient(90deg, var(--primary), var(--accent), var(--secondary));
    }

    .header-title {
        font-family: 'Space Grotesk', sans-serif;
        font-size: 2rem;
        font-weight: 700;
        color: var(--text-dark);
        margin-bottom: 8px;
        display: flex;
        align-items: center;
        gap: 14px;
    }
    .header-title i {
        width: 50px;
        height: 50px;
        background: linear-gradient(135deg, var(--primary), var(--secondary));
        border-radius: 16px;
        display: flex;
        align-items: center;
        justify-content: center;
        color: white;
        font-size: 1.2rem;
    }

    .header-subtitle { color: var(--text-muted); font-size: 1rem; margin-left: 64px; }

    .header-stats {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 20px;
        margin-top: 28px;
        padding-top: 28px;
        border-top: 2px solid #f1f5f9;
    }

    .stat-card {
        text-align: center;
        padding: 20px;
        background: linear-gradient(135deg, rgba(5, 150, 105, 0.04), rgba(245, 158, 11, 0.04));
        border-radius: 16px;
        transition: all 0.3s ease;
    }
    .stat-card:hover { transform: translateY(-4px); box-shadow: 0 10px 30px rgba(5, 150, 105, 0.1); }

    .stat-value {
        font-family: 'Space Grotesk', sans-serif;
        font-size: 2.2rem;
        font-weight: 700;
        background: linear-gradient(135deg, var(--primary), var(--accent));
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        line-height: 1;
    }
    .stat-label { color: var(--text-muted); font-size: 0.85rem; font-weight: 600; margin-top: 8px; }

    .inscriptions-list { margin-top: 32px; }

    .inscription-item {
        background: white;
        border-radius: 20px;
        padding: 24px 28px;
        margin-bottom: 16px;
        box-shadow: 0 4px 20px rgba(0, 0, 0, 0.04);
        border: 1px solid rgba(0, 0, 0, 0.04);
        display: flex;
        justify-content: space-between;
        align-items: center;
        flex-wrap: wrap;
        gap: 20px;
        transition: all 0.4s cubic-bezier(0.34, 1.56, 0.64, 1);
        animation: fadeInUp 0.5s ease-out both;
        position: relative;
        overflow: hidden;
    }
    .inscription-item::before {
        content: '';
        position: absolute;
        left: 0;
        top: 0;
        width: 4px;
        height: 100%;
        border-radius: 4px 0 0 4px;
        transition: all 0.3s ease;
    }
    .inscription-item:nth-child(1) { animation-delay: 0.1s; }
    .inscription-item:nth-child(2) { animation-delay: 0.15s; }
    .inscription-item:nth-child(3) { animation-delay: 0.2s; }
    .inscription-item:nth-child(4) { animation-delay: 0.25s; }
    .inscription-item:nth-child(5) { animation-delay: 0.3s; }

    .inscription-item:hover {
        transform: translateY(-6px);
        box-shadow: 0 20px 50px rgba(5, 150, 105, 0.12);
    }

    .inscription-item.pending::before { background: linear-gradient(180deg, var(--warning), #d97706); }
    .inscription-item.confirmed::before { background: linear-gradient(180deg, var(--success), #16a34a); }
    .inscription-item.rejected::before { background: linear-gradient(180deg, var(--danger), #dc2626); }

    .user-info { flex: 1; min-width: 280px; }

    .user-name {
        font-family: 'Space Grotesk', sans-serif;
        font-size: 1.1rem;
        font-weight: 700;
        color: var(--text-dark);
        margin-bottom: 10px;
        display: flex;
        align-items: center;
        gap: 12px;
    }

    .user-avatar {
        width: 46px;
        height: 46px;
        border-radius: 14px;
        background: linear-gradient(135deg, var(--primary), var(--accent));
        color: white;
        display: flex;
        align-items: center;
        justify-content: center;
        font-weight: 700;
        font-size: 0.95rem;
        box-shadow: 0 4px 15px rgba(5, 150, 105, 0.3);
    }

    .user-details {
        display: flex;
        gap: 20px;
        margin-top: 10px;
        flex-wrap: wrap;
        font-size: 0.9rem;
    }

    .detail-item {
        display: flex;
        align-items: center;
        gap: 8px;
        color: var(--text-muted);
        padding: 6px 12px;
        background: #f8fafc;
        border-radius: 8px;
    }
    .detail-item i { color: var(--primary); width: 16px; }

    .status-section {
        display: flex;
        align-items: center;
        gap: 16px;
        flex-wrap: wrap;
    }

    .status-badge {
        padding: 10px 20px;
        border-radius: 50px;
        font-size: 0.8rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        white-space: nowrap;
        display: flex;
        align-items: center;
        gap: 8px;
    }

    .status-pending {
        background: linear-gradient(135deg, rgba(245, 158, 11, 0.12), rgba(245, 158, 11, 0.05));
        color: var(--warning);
        border: 1px solid rgba(245, 158, 11, 0.3);
    }

    .status-confirmed {
        background: linear-gradient(135deg, rgba(34, 197, 94, 0.12), rgba(34, 197, 94, 0.05));
        color: var(--success);
        border: 1px solid rgba(34, 197, 94, 0.3);
    }

    .status-rejected {
        background: linear-gradient(135deg, rgba(239, 68, 68, 0.12), rgba(239, 68, 68, 0.05));
        color: var(--danger);
        border: 1px solid rgba(239, 68, 68, 0.3);
    }

    .action-buttons { display: flex; gap: 10px; flex-wrap: wrap; }

    .btn-action {
        padding: 10px 20px;
        border: none;
        border-radius: 12px;
        font-size: 0.85rem;
        font-weight: 700;
        cursor: pointer;
        transition: all 0.4s cubic-bezier(0.34, 1.56, 0.64, 1);
        display: inline-flex;
        align-items: center;
        gap: 8px;
        white-space: nowrap;
        position: relative;
        overflow: hidden;
    }
    .btn-action::before {
        content: '';
        position: absolute;
        top: 0;
        left: -100%;
        width: 100%;
        height: 100%;
        background: linear-gradient(90deg, transparent, rgba(255,255,255,0.3), transparent);
        transition: left 0.5s ease;
    }
    .btn-action:hover::before { left: 100%; }

    .btn-approve {
        background: linear-gradient(135deg, var(--success), #16a34a);
        color: white;
        box-shadow: 0 4px 15px rgba(34, 197, 94, 0.3);
    }
    .btn-approve:hover {
        transform: translateY(-3px);
        box-shadow: 0 8px 25px rgba(34, 197, 94, 0.4);
    }

    .btn-reject {
        background: linear-gradient(135deg, var(--danger), #dc2626);
        color: white;
        box-shadow: 0 4px 15px rgba(239, 68, 68, 0.3);
    }
    .btn-reject:hover {
        transform: translateY(-3px);
        box-shadow: 0 8px 25px rgba(239, 68, 68, 0.4);
    }

    .btn-pending {
        background: linear-gradient(135deg, var(--warning), #d97706);
        color: white;
        box-shadow: 0 4px 15px rgba(245, 158, 11, 0.3);
    }
    .btn-pending:hover {
        transform: translateY(-3px);
        box-shadow: 0 8px 25px rgba(245, 158, 11, 0.4);
    }

    .no-inscriptions {
        text-align: center;
        padding: 80px 20px;
        background: white;
        border-radius: 24px;
        box-shadow: 0 4px 20px rgba(0, 0, 0, 0.04);
        animation: fadeInUp 0.6s ease-out;
    }
    .no-inscriptions-icon {
        width: 100px;
        height: 100px;
        margin: 0 auto 24px;
        background: linear-gradient(135deg, rgba(5, 150, 105, 0.1), rgba(245, 158, 11, 0.1));
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
    }
    .no-inscriptions-icon i { font-size: 2.5rem; color: var(--text-muted); opacity: 0.5; }
    .no-inscriptions h2 {
        font-family: 'Space Grotesk', sans-serif;
        color: var(--text-dark);
        font-size: 1.5rem;
        margin-bottom: 10px;
    }
    .no-inscriptions p { color: var(--text-muted); }

    .btn-back {
        display: inline-flex;
        align-items: center;
        gap: 10px;
        margin-top: 40px;
        padding: 14px 28px;
        background: linear-gradient(135deg, var(--primary), var(--secondary));
        color: white;
        border-radius: 14px;
        text-decoration: none;
        font-weight: 700;
        transition: all 0.4s cubic-bezier(0.34, 1.56, 0.64, 1);
        box-shadow: 0 8px 25px rgba(5, 150, 105, 0.3);
    }
    .btn-back:hover {
        transform: translateY(-4px);
        box-shadow: 0 15px 40px rgba(5, 150, 105, 0.4);
        color: white;
    }

    @@media (max-width: 768px) {
        .header-stats { grid-template-columns: 1fr; }
        .inscription-item { flex-direction: column; align-items: flex-start; }
        .status-section { width: 100%; justify-content: space-between; }
        .action-buttons { width: 100%; }
        .btn-action { flex: 1; justify-content: center; }
    }
</style>

<div class="inscriptions-container">
    <div class="inscriptions-header">
        <div class="breadcrumb-nav">
            <a asp-controller="Home" asp-action="Index"><i class="fas fa-home"></i> Accueil</a>
            <span>/</span>
            <a asp-controller="Event" asp-action="Index"><i class="fas fa-calendar-alt"></i> Événements</a>
            <span>/</span>
            <span>Inscriptions</span>
        </div>

        <div class="header-content">
            <h1 class="header-title">
                <i class="fas fa-clipboard-list"></i>
                <span>@ViewBag.EventTitle</span>
            </h1>
            <p class="header-subtitle">Gestion des inscriptions pour cet événement</p>

            @if (Model != null && Model.Count > 0)
            {
                <div class="header-stats">
                    <div class="stat-card">
                        <div class="stat-value">@Model.Count</div>
                        <div class="stat-label">Inscriptions totales</div>
                    </div>
                    <div class="stat-card">
                        <div class="stat-value">@Model.Count(i => i.Statut == "En attente")</div>
                        <div class="stat-label">En attente</div>
                    </div>
                    <div class="stat-card">
                        <div class="stat-value">@Model.Count(i => i.Statut == "Confirmée")</div>
                        <div class="stat-label">Confirmées</div>
                    </div>
                </div>
            }
        </div>
    </div>

    @if (Model != null && Model.Count > 0)
    {
        <div class="inscriptions-list">
            @foreach (var inscription in Model)
            {
                var statusClass = inscription.Statut == "En attente" ? "pending" : (inscription.Statut == "Confirmée" ? "confirmed" : "rejected");
                var statusBadgeClass = inscription.Statut == "En attente" ? "status-pending" : (inscription.Statut == "Confirmée" ? "status-confirmed" : "status-rejected");

                var nomLettre = !string.IsNullOrEmpty(inscription.User?.LastName) ? inscription.User.LastName.FirstOrDefault().ToString() : "U";
                var prenomLettre = !string.IsNullOrEmpty(inscription.User?.FirstName) ? inscription.User.FirstName.FirstOrDefault().ToString() : "U";
                var initials = (nomLettre + prenomLettre).ToUpper();

                var userLastName = inscription.User?.LastName ?? "Utilisateur";
                var userFirstName = inscription.User?.FirstName ?? "";

                <div class="inscription-item @statusClass">
                    <div class="user-info">
                        <div class="user-name">
                            <div class="user-avatar">@initials</div>
                            <span>@userLastName @userFirstName</span>
                        </div>
                        <div class="user-details">
                            <div class="detail-item">
                                <i class="fas fa-envelope"></i>
                                <span>@inscription.User?.Email</span>
                            </div>
                            <div class="detail-item">
                                <i class="fas fa-calendar"></i>
                                <span>Inscrit le @inscription.DateInscription.ToString("dd/MM/yyyy à HH:mm")</span>
                            </div>
                        </div>
                    </div>

                    <div class="status-section">
                        <div class="status-badge @statusBadgeClass">
                            @if (inscription.Statut == "En attente")
                            {
                                <i class="fas fa-hourglass-half"></i>
                                <span>En attente</span>
                            }
                            else if (inscription.Statut == "Confirmée")
                            {
                                <i class="fas fa-check-circle"></i>
                                <span>Confirmée</span>
                            }
                            else
                            {
                                <i class="fas fa-times-circle"></i>
                                <span>Rejetée</span>
                            }
                        </div>

                        <div class="action-buttons">
                            @if (inscription.Statut != "Confirmée")
                            {
                                <button class="btn-action btn-approve" onclick="updateStatus(@inscription.Id, 'Confirmée')">
                                    <i class="fas fa-check"></i> Accepter
                                </button>
                            }
                            @if (inscription.Statut != "Rejetée")
                            {
                                <button class="btn-action btn-reject" onclick="updateStatus(@inscription.Id, 'Rejetée')">
                                    <i class="fas fa-times"></i> Rejeter
                                </button>
                            }
                            @if (inscription.Statut != "En attente")
                            {
                                <button class="btn-action btn-pending" onclick="updateStatus(@inscription.Id, 'En attente')">
                                    <i class="fas fa-history"></i> Attente
                                </button>
                            }
                        </div>
                    </div>
                </div>
            }
        </div>
    }
    else
    {
        <div class="no-inscriptions">
            <div class="no-inscriptions-icon">
                <i class="fas fa-inbox"></i>
            </div>
            <h2>Aucune inscription</h2>
            <p>Il n'y a pas encore d'inscription pour cet événement.</p>
        </div>
    }

    <a asp-controller="Event" asp-action="Index" class="btn-back">
        <i class="fas fa-arrow-left"></i> Retour aux événements
    </a>
</div>

<script>
    function getAntiForgeryToken() {
        const tokenInput = document.querySelector('input[name="__RequestVerificationToken"]');
        if (!tokenInput) {
            console.error('CSRF token not found');
            return '';
        }
        return tokenInput.value;
    }

    function updateStatus(inscriptionId, newStatus) {
        if (!inscriptionId || isNaN(inscriptionId)) {
            alert('Erreur: ID d\'inscription invalide.');
            return;
        }

        const numericId = parseInt(inscriptionId, 10);
        const statusText = newStatus === 'Confirmée' ? 'confirmée' : (newStatus === 'Rejetée' ? 'rejetée' : 'mise en attente');

        if (!confirm(`Êtes-vous sûr de vouloir mettre cette inscription à "${statusText}" ?`)) {
            return;
        }

        const token = getAntiForgeryToken();
        if (!token) {
            alert('Erreur de sécurité: Token CSRF non trouvé.');
            return;
        }

        const payload = {
            inscriptionId: numericId,
            newStatus: newStatus
        };

        fetch('/Event/UpdateInscriptionStatus', {
            method: 'POST',
            headers: {
                'Content-Type': 'application/json',
                'RequestVerificationToken': token
            },
            body: JSON.stringify(payload)
        })
        .then(response => {
            if (!response.ok) {
                throw new Error(`HTTP error! status: ${response.status}`);
            }
            return response.json();
        })
        .then(data => {
            if (data.success) {
                const message = newStatus === 'Confirmée' 
                    ? 'Statut mis à jour! Un email de confirmation a été envoyé.' 
                    : 'Statut mis à jour!';
                alert(message);
                location.reload();
            } else {
                alert('Erreur: ' + (data.message || 'Erreur inconnue'));
            }
        })
        .catch(error => {
            console.error('Fetch error:', error);
            alert('Une erreur est survenue lors de la mise à jour.');
        });
    }
</script>
