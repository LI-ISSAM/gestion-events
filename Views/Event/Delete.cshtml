@model Event
@{
    ViewData["Title"] = "Supprimer un événement";
}

<style>
    :root {
        --primary: #1e40af;
        --accent: #ec4899;
        --danger: #ef4444;
        --border: #e5e7eb;
    }

    .delete-container {
        max-width: 500px;
        margin: 0 auto;
        animation: fadeIn 0.6s ease-out;
    }

    .delete-card {
        background: white;
        border-radius: 16px;
        box-shadow: 0 10px 40px rgba(0, 0, 0, 0.1);
        border: 1px solid var(--border);
        overflow: hidden;
    }

    .delete-header {
        background: linear-gradient(135deg, var(--danger) 0%, #b91c1c 100%);
        color: white;
        padding: 40px 30px;
        text-align: center;
    }

    .delete-header h1 {
        font-size: 1.8rem;
        font-weight: 700;
        margin: 0;
    }

    .delete-header p {
        margin-top: 8px;
        opacity: 0.9;
    }

    .delete-content {
        padding: 40px;
    }

    .delete-info {
        background: rgba(239, 68, 68, 0.1);
        border-left: 4px solid var(--danger);
        border-radius: 8px;
        padding: 20px;
        margin-bottom: 30px;
    }

    .event-details {
        display: flex;
        gap: 20px;
        margin-bottom: 30px;
        padding: 20px;
        background: #f8fafc;
        border-radius: 10px;
    }

    .event-image-preview {
        width: 100px;
        height: 100px;
        border-radius: 8px;
        object-fit: cover;
        flex-shrink: 0;
    }

    .event-info h3 {
        font-size: 1.1rem;
        font-weight: 700;
        color: #1f2937;
        margin-bottom: 5px;
    }

    .event-info p {
        color: #6b7280;
        font-size: 0.9rem;
        margin-bottom: 5px;
    }

    .delete-actions {
        display: flex;
        gap: 12px;
        justify-content: flex-end;
    }

    .btn {
        padding: 12px 28px;
        border: none;
        border-radius: 8px;
        font-size: 1rem;
        font-weight: 600;
        cursor: pointer;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 8px;
        transition: all 0.3s ease;
    }

    .btn-delete {
        background: linear-gradient(135deg, var(--danger) 0%, #b91c1c 100%);
        color: white;
    }

    .btn-delete:hover {
        transform: translateY(-2px);
        box-shadow: 0 8px 25px rgba(239, 68, 68, 0.3);
    }

    .btn-cancel {
        background: #f3f4f6;
        color: #6b7280;
        border: 2px solid var(--border);
    }

    .btn-cancel:hover {
        background: #e5e7eb;
        border-color: #6b7280;
    }

    @@keyframes fadeIn {
        from { opacity: 0; transform: translateY(20px); }
        to { opacity: 1; transform: translateY(0); }
    }

    @@media (max-width: 576px) {
        .delete-container {
            margin: -20px -15px;
        }
        .delete-card {
            border-radius: 0;
        }
        .delete-content {
            padding: 25px;
        }
        .delete-actions {
            flex-direction: column;
        }
        .btn {
            width: 100%;
        }
        .event-details {
            flex-direction: column;
            align-items: center;
            text-align: center;
        }
    }
</style>

<div class="delete-container">
    <div class="delete-card">
        <div class="delete-header">
            <h1>
                <i class="fas fa-exclamation-triangle me-2"></i>Supprimer l'événement
            </h1>
            <p>Cette action est irréversible</p>
        </div>

        <div class="delete-content">
            <div class="delete-info">
                <i class="fas fa-warning me-2"></i>
                <strong>Attention!</strong> La suppression de cet événement ne peut pas être annulée. Toutes les inscriptions seront également supprimées.
            </div>

            <div class="event-details">
                @if (!string.IsNullOrEmpty(Model.ImageUrl))
                {
                    <img src="@Model.ImageUrl" alt="@Model.Titre" class="event-image-preview" />
                }
                <div class="event-info">
                    <h3>@Model.Titre</h3>
                    <p><strong>Date:</strong> @Model.DateEvent.ToString("dd/MM/yyyy à HH:mm")</p>
                    <p><strong>Lieu:</strong> @Model.Lieu</p>
                    <p><strong>Prix:</strong> @Model.Prix.ToString("0.00") DH</p>
                </div>
            </div>

            <form asp-action="Delete" method="post">
                <input type="hidden" name="id" value="@Model.Id" />
                <div class="delete-actions">
                    <a asp-action="Index" class="btn btn-cancel">
                        <i class="fas fa-times"></i>Annuler
                    </a>
                    <button type="submit" class="btn btn-delete">
                        <i class="fas fa-trash"></i>Confirmer la suppression
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>
