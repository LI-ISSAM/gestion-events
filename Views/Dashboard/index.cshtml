@model DashboardViewModel

@{
    ViewData["Title"] = "Dashboard";
}

<style>
    :root {
        --primary: #059669;
        --primary-dark: #047857;
        --accent: #f59e0b;
        --secondary: #0d9488;
        --success: #22c55e;
        --warning: #f59e0b;
        --danger: #ef4444;
        --text-dark: #0f172a;
        --text-muted: #64748b;
    }

    @@keyframes fadeInUp { from { opacity: 0; transform: translateY(30px); } to { opacity: 1; transform: translateY(0); } }
    @@keyframes slideInRight { from { opacity: 0; transform: translateX(40px); } to { opacity: 1; transform: translateX(0); } }
    @@keyframes countUp { from { transform: translateY(20px); opacity: 0; } to { transform: translateY(0); opacity: 1; } }
    @@keyframes pulse { 0%, 100% { transform: scale(1); } 50% { transform: scale(1.05); } }
    @@keyframes gradient-shift { 0%, 100% { background-position: 0% 50%; } 50% { background-position: 100% 50%; } }

    .dashboard-container { padding: 20px 0; }

    .dashboard-header { margin-bottom: 50px; animation: fadeInUp 0.6s ease-out; }
    .header-badge {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        background: linear-gradient(135deg, rgba(5, 150, 105, 0.1), rgba(245, 158, 11, 0.1));
        border: 1px solid rgba(5, 150, 105, 0.2);
        border-radius: 50px;
        padding: 10px 24px;
        font-size: 0.85rem;
        font-weight: 600;
        color: var(--primary);
        margin-bottom: 16px;
    }
    .dashboard-header h1 {
        font-family: 'Space Grotesk', sans-serif;
        font-size: 2.8rem;
        font-weight: 700;
        color: var(--text-dark);
        margin-bottom: 10px;
        letter-spacing: -1.5px;
    }
    .dashboard-header p { color: var(--text-muted); font-size: 1.1rem; }

    /* Stats Grid */
    .stats-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 24px; margin-bottom: 50px; }
    .stat-card {
        background: white;
        border-radius: 24px;
        padding: 32px;
        border: 1px solid rgba(0, 0, 0, 0.04);
        box-shadow: 0 4px 20px rgba(0, 0, 0, 0.04);
        position: relative;
        overflow: hidden;
        animation: fadeInUp 0.6s ease-out both;
        transition: all 0.4s cubic-bezier(0.34, 1.56, 0.64, 1);
    }
    .stat-card:nth-child(1) { animation-delay: 0.1s; }
    .stat-card:nth-child(2) { animation-delay: 0.15s; }
    .stat-card:nth-child(3) { animation-delay: 0.2s; }
    .stat-card:nth-child(4) { animation-delay: 0.25s; }
    .stat-card::before {
        content: '';
        position: absolute;
        top: 0;
        left: 0;
        width: 4px;
        height: 100%;
        background: linear-gradient(180deg, var(--primary), var(--accent));
        border-radius: 4px 0 0 4px;
    }
    .stat-card:hover { transform: translateY(-8px); box-shadow: 0 25px 60px rgba(5, 150, 105, 0.12); }
    .stat-icon {
        width: 60px;
        height: 60px;
        background: linear-gradient(135deg, rgba(5, 150, 105, 0.1), rgba(245, 158, 11, 0.1));
        border-radius: 18px;
        display: flex;
        align-items: center;
        justify-content: center;
        margin-bottom: 20px;
    }
    .stat-icon i { color: var(--primary); font-size: 1.5rem; }
    .stat-label { color: var(--text-muted); font-size: 0.9rem; font-weight: 600; margin-bottom: 8px; }
    .stat-value {
        font-family: 'Space Grotesk', sans-serif;
        font-size: 2.8rem;
        font-weight: 700;
        background: linear-gradient(135deg, var(--primary), var(--accent));
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        line-height: 1;
    }

    /* Content Grid */
    .content-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(450px, 1fr)); gap: 32px; margin-bottom: 32px; }
    .card {
        background: white;
        border-radius: 24px;
        padding: 36px;
        border: 1px solid rgba(0, 0, 0, 0.04);
        box-shadow: 0 4px 20px rgba(0, 0, 0, 0.04);
        animation: fadeInUp 0.6s ease-out 0.3s both;
        transition: all 0.3s ease;
        margin-bottom: 15px;
    }
    .card:hover { box-shadow: 0 20px 50px rgba(5, 150, 105, 0.08); transform: translateY(-4px); }
    .card-title {
        font-family: 'Space Grotesk', sans-serif;
        font-size: 1.3rem;
        font-weight: 700;
        color: var(--text-dark);
        margin-bottom: 28px;
        display: flex;
        align-items: center;
        gap: 14px;
        padding-bottom: 20px;
        border-bottom: 2px solid #f1f5f9;
    }
    .card-title i {
        width: 44px;
        height: 44px;
        background: linear-gradient(135deg, var(--primary), var(--secondary));
        border-radius: 14px;
        display: flex;
        align-items: center;
        justify-content: center;
        color: white;
        font-size: 1rem;
    }

    .list-item {
        padding: 20px 0;
        border-bottom: 1px solid #f1f5f9;
        display: flex;
        justify-content: space-between;
        align-items: center;
        transition: all 0.3s ease;
        animation: countUp 0.5s ease-out forwards;
        opacity: 0;
    }
    .list-item:nth-child(1) { animation-delay: 0.4s; }
    .list-item:nth-child(2) { animation-delay: 0.45s; }
    .list-item:nth-child(3) { animation-delay: 0.5s; }
    .list-item:hover { background: linear-gradient(90deg, rgba(5, 150, 105, 0.04), transparent); padding-left: 12px; border-radius: 12px; }
    .list-item:last-child { border-bottom: none; }
    .item-name { font-weight: 700; color: var(--text-dark); font-size: 0.95rem; margin-bottom: 4px; }
    .item-meta { color: var(--text-muted); font-size: 0.85rem; display: flex; align-items: center; gap: 6px; }

    .badge {
        display: inline-block;
        padding: 8px 16px;
        border-radius: 50px;
        font-size: 0.8rem;
        font-weight: 700;
    }
    .badge-success { background: linear-gradient(135deg, rgba(34, 197, 94, 0.12), rgba(34, 197, 94, 0.05)); color: var(--success); border: 1px solid rgba(34, 197, 94, 0.3); }
    .badge-warning { background: linear-gradient(135deg, rgba(245, 158, 11, 0.12), rgba(245, 158, 11, 0.05)); color: var(--warning); border: 1px solid rgba(245, 158, 11, 0.3); }

    .btn-view-all {
        display: inline-flex;
        align-items: center;
        gap: 10px;
        margin-top: 24px;
        padding: 14px 28px;
        background: linear-gradient(135deg, var(--primary), var(--secondary));
        color: white;
        border-radius: 14px;
        text-decoration: none;
        font-weight: 700;
        transition: all 0.4s cubic-bezier(0.34, 1.56, 0.64, 1);
        box-shadow: 0 8px 25px rgba(5, 150, 105, 0.3);
    }
    .btn-view-all:hover { transform: translateY(-4px); box-shadow: 0 15px 40px rgba(5, 150, 105, 0.4); color: white; }

    .quick-actions { display: grid; grid-template-columns: repeat(auto-fit, minmax(160px, 1fr)); gap: 16px; margin-top: 24px; }

    .empty-state { text-align: center; padding: 40px; color: var(--text-muted); }
    .empty-state i { font-size: 2.5rem; margin-bottom: 12px; opacity: 0.4; }

    .btn-manage-small {
        display: inline-flex;
        align-items: center;
        gap: 10px;
        padding: 8px 16px;
        background: linear-gradient(135deg, var(--primary-dark), var(--secondary));
        color: white;
        border-radius: 14px;
        text-decoration: none;
        font-weight: 700;
        transition: all 0.4s cubic-bezier(0.34, 1.56, 0.64, 1);
        box-shadow: 0 4px 15px rgba(5, 150, 105, 0.2);
    }
    .btn-manage-small:hover { transform: translateY(-2px); box-shadow: 0 8px 20px rgba(5, 150, 105, 0.3); color: white; }

    @@media (max-width: 992px) { .content-grid { grid-template-columns: 1fr; } }
    @@media (max-width: 768px) { .dashboard-header h1 { font-size: 2rem; } .stats-grid { grid-template-columns: 1fr 1fr; } }
</style>

<div class="dashboard-container">
    <div class="dashboard-header">
        <div class="header-badge"><i class="fas fa-crown"></i> Espace Administrateur</div>
        <h1>Dashboard</h1>
        <p>Bienvenue dans votre centre de contrôle</p>
    </div>

    <div class="stats-grid">
        <div class="stat-card">
            <div class="stat-icon"><i class="fas fa-calendar-alt"></i></div>
            <div class="stat-label">Événements totaux</div>
            <div class="stat-value">@Model.TotalEvents</div>
        </div>
        <div class="stat-card">
            <div class="stat-icon"><i class="fas fa-users"></i></div>
            <div class="stat-label">Utilisateurs</div>
            <div class="stat-value">@Model.TotalUsers</div>
        </div>
        <div class="stat-card">
            <div class="stat-icon"><i class="fas fa-ticket-alt"></i></div>
            <div class="stat-label">Inscriptions</div>
            <div class="stat-value">@Model.TotalInscriptions</div>
        </div>
        <div class="stat-card">
            <div class="stat-icon"><i class="fas fa-hourglass-half"></i></div>
            <div class="stat-label">En attente</div>
            <div class="stat-value">@Model.PendingInscriptions</div>
        </div>
    </div>

    <div class="content-grid">
        <div class="card">
            <h3 class="card-title"><i class="fas fa-calendar-check"></i> Événements à venir</h3>
            @if (Model.UpcomingEvents.Any())
            {
                @foreach (var evt in Model.UpcomingEvents)
                {
                    <div class="list-item">
                        <div>
                            <div class="item-name">@evt.Titre</div>
                            <div class="item-meta"><i class="fas fa-calendar"></i> @evt.DateEvent.ToString("dd/MM/yyyy HH:mm")</div>
                        </div>
                        <a href="@Url.Action("Details", "Event", new { id = evt.Id })" style="color: var(--primary);"><i class="fas fa-arrow-right"></i></a>
                    </div>
                }
            }
            else { <div class="empty-state"><i class="fas fa-calendar-times"></i><p>Aucun événement à venir</p></div> }
            <a href="@Url.Action("Index", "Event")" class="btn-view-all"><i class="fas fa-list"></i> Voir tous</a>
        </div>

        <div class="card">
            <h3 class="card-title"><i class="fas fa-user-plus"></i> Utilisateurs récents</h3>
            @if (Model.RecentUsers.Any())
            {
                @foreach (var user in Model.RecentUsers)
                {
                    <div class="list-item">
                        <div>
                            <div class="item-name">@user.FirstName @user.LastName</div>
                            <div class="item-meta"><i class="fas fa-envelope"></i> @user.Email</div>
                        </div>
                    </div>
                }
            }
            else { <div class="empty-state"><i class="fas fa-users-slash"></i><p>Aucun utilisateur récent</p></div> }
            <a href="@Url.Action("ManageUsers", "Dashboard")" class="btn-view-all"><i class="fas fa-users-cog"></i> Gérer</a>
        </div>
    </div>

    @if (Model.RecentComments.Any())
    {
        <div class="card">
            <h3 class="card-title"><i class="fas fa-comments"></i> Commentaires récents</h3>
            @foreach (var comment in Model.RecentComments)
            {
                <div class="list-item">
                    <div style="flex: 1;">
                        <div class="item-name"><i class="fas fa-user-circle me-2" style="color: var(--primary);"></i>@comment.User?.FirstName @comment.User?.LastName</div>
                        <div class="item-meta" style="margin: 6px 0;">@comment.Event?.Titre</div>
                        <div style="color: var(--text-dark); font-style: italic;">"@comment.Texte"</div>
                        <div class="item-meta" style="margin-top: 8px; color: var(--accent);"><i class="fas fa-star"></i> @comment.Note/5 - @comment.DateCreation.ToString("dd/MM/yyyy")</div>
                    </div>
                </div>
            }
        </div>
    }

    @if (Model.PendingRegistrations.Any())
    {
        <div class="card">
            <h3 class="card-title"><i class="fas fa-clock"></i> Inscriptions en attente</h3>
            @foreach (var reg in Model.PendingRegistrations)
            {
                <div class="list-item">
                    <div>
                        <div class="item-name">@reg.User.FirstName @reg.User.LastName</div>
                        <div class="item-meta">@reg.Event.Titre - @reg.DateInscription.ToString("dd/MM/yyyy")</div>
                    </div>
                    <div style="display: flex; align-items: center; gap: 12px;">
                        <span class="badge badge-warning">En attente</span>
                        <a href="@Url.Action("Inscriptions", "Event", new { eventId = reg.Event.Id })" class="btn-manage-small">
                            <i class="fas fa-cog"></i> Gérer
                        </a>
                    </div>
                </div>
            }
        </div>
    }

    <div class="card">
        <h3 class="card-title"><i class="fas fa-bolt"></i> Actions rapides</h3>
        <div class="quick-actions">
            <a href="@Url.Action("Create", "Event")" class="btn-view-all"><i class="fas fa-plus"></i> Créer</a>
            <a href="@Url.Action("Statistics", "Dashboard")" class="btn-view-all"><i class="fas fa-chart-bar"></i> Stats</a>
            <a href="@Url.Action("ManageUsers", "Dashboard")" class="btn-view-all"><i class="fas fa-users"></i> Users</a>
        </div>
    </div>
</div>
